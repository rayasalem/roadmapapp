NODE_ENV=development
PORT=4000
# Frontend URL(s) for CORS. Production (e.g. Render): comma-separated list
# Example: CLIENT_URL=https://roadmapapp.vercel.app,https://your-app.vercel.app
CLIENT_URL=http://localhost:8081
JWT_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
BCRYPT_ROUNDS=12
# Optional: 32-byte hex key for encryptSensitive/decryptSensitive (e.g. tokens at rest)
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
